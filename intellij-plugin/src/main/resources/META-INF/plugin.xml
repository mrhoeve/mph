<idea-plugin>
    <id>nl.hicts.mph.plugin</id>
    <name>Maven Project Helper</name>
    <vendor url="https://github.com/mrhoeve/mph">MPH</vendor>

    <description><![CDATA[
        Manage versions, builds, dependencies, and Git synchronization across a Maven workspace from IntelliJ IDEA.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.idea.maven</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
                id="Maven Project Helper"
                displayType="BALLOON"
                isLogByDefault="true"/>
        <toolWindow
                id="MPH"
                anchor="right"
                icon="/icons/mph.svg"
                factoryClass="nl.hicts.mph.intellij.ui.MphToolWindowFactory"/>
        <applicationConfigurable
                parentId="tools"
                instance="nl.hicts.mph.intellij.ui.NexusIqConfigurable"
                id="nl.hicts.mph.intellij.settings"
                displayName="Maven Project Helper"/>
    </extensions>

    <actions>
        <action
                id="nl.hicts.mph.intellij.UpdateDependentProjects"
                class="nl.hicts.mph.intellij.actions.UpdateDependentProjectsAction"
                text="Update Dependent Maven Projects…"
                description="Find linked Maven projects that reference this project"
                icon="nl.hicts.mph.intellij.icons.MphIcons.Mph">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
